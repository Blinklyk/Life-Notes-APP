# 使用 `openssl rand -hex 32` 生成，不要提交真实值。
LIFE_NOTES_BEARER_TOKEN=
DEEPSEEK_API_KEY=

# 也可设为兼容根路径 https://api.deepseek.com/v1，服务只追加 /chat/completions。

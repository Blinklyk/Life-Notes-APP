DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_TIMEOUT_SECONDS=30
DEEPSEEK_MAX_OUTPUT_TOKENS=2000
MAX_REQUEST_BODY_BYTES=131072
RATE_LIMIT_REQUESTS_PER_MINUTE=10
